# Copy this file to .env and fill in your values
# Never commit .env to git

# Lewis API key (for translation — build.lewisnote.com)
LEWIS_API_KEY=your_lewis_api_key_here

# Admin dashboard password
OREUS_ADMIN_KEY=change-me-in-production

# ── Anti-abuse limits (optional — sensible defaults if unset) ──
# Per-IP sliding-window rate limits on the expensive endpoints.
OREUS_RL_UPLOAD_BURST=8       # max uploads / 15 min / IP
OREUS_RL_UPLOAD_DAY=30        # max uploads / day / IP
OREUS_RL_PROCESS_BURST=8      # max process calls / 15 min / IP
OREUS_RL_PROCESS_DAY=30       # max process calls / day / IP
OREUS_MAX_ACTIVE_PER_IP=2     # max concurrent jobs (queued+processing) per IP
OREUS_MAX_ACTIVE_GLOBAL=12    # max concurrent jobs across the whole server
