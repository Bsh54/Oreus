# Copy this file to .env and fill in your values
# Never commit .env to git

# Gemini API key (for translation — Google AI Studio, https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here
# Optional: translation model (default gemini-flash-lite-latest)
# GEMINI_MODEL=gemini-flash-lite-latest

# Admin dashboard password
OREUS_ADMIN_KEY=change-me-in-production

# ── Anti-abuse limits (optional — sensible defaults if unset) ──
# Per-IP sliding-window rate limits on the expensive endpoints.
OREUS_RL_UPLOAD_BURST=8       # max uploads / 15 min / IP
OREUS_RL_UPLOAD_DAY=3         # max uploads / day / IP (free tier)
OREUS_RL_PROCESS_BURST=8      # max process calls / 15 min / IP
OREUS_RL_PROCESS_DAY=3        # max process calls / day / IP (free tier)
OREUS_MAX_ACTIVE_PER_IP=2     # max concurrent jobs (queued+processing) per IP
OREUS_MAX_ACTIVE_GLOBAL=12    # max concurrent jobs across the whole server

# ── Disk safety net (optional) ──
# When free disk drops below MIN, finished videos are deleted early (downloaded
# ones first), without waiting for the 24h cleanup, until TARGET free GB is back.
OREUS_DISK_MIN_FREE_GB=2.5    # start emergency cleanup below this many GB free
OREUS_DISK_TARGET_FREE_GB=4.5 # clean until at least this many GB are free
